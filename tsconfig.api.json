{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "types": [
      "node"
    ],
    "outDir": "./dist/api-check"
  },
  "include": [
    "api/**/*.ts"
  ]
}
